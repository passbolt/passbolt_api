#!/usr/bin/env bash
# This script is executed as part of a cronjob task
# is already run as www-data or any other web user.

set -euo pipefail

DIGEST_ENABLED=${PASSBOLT_PLUGINS_EMAIL_DIGEST_ENABLED:-1}

DIR=$(dirname "$(readlink -f "$0")")

if [[ "$DIGEST_ENABLED" = 1 ]]; then
    "$DIR"/cake passbolt email_digest send
else
    "$DIR"/cake EmailQueue.sender
fi

TIME=$(date +%H:%M);
if [ "$TIME" = "06:00" ]; then
    RUN_DAILY_COMMAND=1;
else
    RUN_DAILY_COMMAND=0;
fi

PASSWORD_EXPIRY_ENABLED=${PASSWORD_EXPIRY_ENABLED:-1}
PASSWORD_EXPIRY_ADVANCED_ENABLED=${PASSWORD_EXPIRY_ADVANCED_ENABLED:-1}
if [ "$PASSWORD_EXPIRY_ENABLED" = 1 ] && [ "$PASSWORD_EXPIRY_ADVANCED_ENABLED" = 1 ] && [ "$RUN_DAILY_COMMAND" = 1 ]; then
    "$DIR"/cake passbolt notify_about_expired_resources
fi
