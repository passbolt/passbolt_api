msgid "You need to login to access this location."
msgstr "Ви повинні увійти, щоб отримати доступ до цього розташування."

msgid "The server verify token is missing or invalid."
msgstr "Токен верифікації сервера відсутній або недійсний."

msgid "Decryption failed."
msgstr "Помилка розшифрування."

msgid "Failed to create token."
msgstr "Не вдалося створити токен."

msgid "The user token result should be a valid UUID."
msgstr "Результат токена користувача має бути дійсним UUID."

msgid "The user token result could not be found "
msgstr "Не вдалось знайти результат за токеном користувача "

msgid "The OpenPGP server key defined in the config cannot be used to decrypt."
msgstr "Вказаний у конфігурації ключ сервера OpenPGP, неможливо використаний для дешифрування."

msgid "Could not import the user OpenPGP key."
msgstr "Не вдалось імпортувати користувацький OpenPGP ключ."

msgid "Invalid verify token type."
msgstr "Невірний тип токена перевірки."

msgid "Invalid verify token format, "
msgstr "Невірний формат токена верифікації, "

msgid "sections are missing or using wrong delimiters."
msgstr "розділи відсутні або мають неправильні роздільники."

msgid "the version numbers do not match."
msgstr "номери версій не збігаються."

msgid "wrong version number."
msgstr "хибний номер версії."

msgid "it is not a UUID."
msgstr "це не UUID."

msgid "wrong token data length."
msgstr "хибна довжина даних токена."

msgid "There is no user associated with this key."
msgstr "Немає користувача, пов’язаного з цим ключем."

msgid "Page not found."
msgstr "Сторінку не знайдено."

msgid "Please use .json extension in URL or accept application/json."
msgstr "Будь ласка, використовуйте .json розширення в URL або прийміть application/json."

msgid "The request data can not be empty."
msgstr "Дані запиту не можуть бути порожніми."

msgid "You are already logged in."
msgstr "Ви вже увійшли."

msgid "You are successfully logged in."
msgstr "Ви успішно увійшли."

msgid "You are successfully logged out."
msgstr "Ви успішно вийшли."

msgid "The logout route should only be accessed with POST method."
msgstr "Маршрут виходу із системи має бути доступний лише через POST метод."

msgid "The OpenPGP public key information was not found in config."
msgstr "Інформацію про публічний ключ OpenPGP не знайдено у конфігурації."

msgid "The operation was successful."
msgstr "Операція пройшла успішно."

msgid "The comment was successfully added."
msgstr "Коментар успішно додано."

msgid "The comment was deleted."
msgstr "Коментар видалено."

msgid "The comment id is not valid."
msgstr "Id коментаря недійсний."

msgid "The comment was successfully updated."
msgstr "Коментар успішно оновлено."

msgid "Invalid order. \"{0}\" is not in the list of allowed order."
msgstr "Некоректна властивість. \"{0}\" відсутній в переліку дозволених властивостей."

msgid "Invalid order. \"{0}\" is not a valid order."
msgstr "Некоректна властивість. \"{0}\" відсутній в переліку доступних властивостей."

msgid "Invalid order. \"{0}\" is not a valid field."
msgstr "Неприпустимий порядок. \"{0}\" не є дійсним полем."

msgid "Invalid pagination."
msgstr "Недійсна нумерація сторінок."

msgid "Invalid query string. The filter parameter should be an array."
msgstr "Некоректний рядок запиту. Параметр фільтра має бути масивом."

msgid "Invalid query string. The contain parameter should be an array."
msgstr "Некоректний рядок запиту. Параметр contain має бути масивом."

msgid "Invalid filter."
msgstr "Недопустимий фільтр."

msgid "Invalid order."
msgstr "Помилка в порядку."

msgid "Invalid contain."
msgstr "Недійсне значення contain."

msgid "No validation rule for filter {0}. Please create one."
msgstr "Немає правила валідації фільтра {0}. Будь ласка, створіть його."

msgid "Filter {0} is not valid."
msgstr "Фільтр {0} не дійсний."

msgid "\"{0}\" is not a valid value for filter {1}."
msgstr "\"{0}\" не є дійсним значенням для фільтра {1}."

msgid "\"{0}\" is not a valid search filter."
msgstr "\"{0}\" не є допустимим пошуковим фільтром."

msgid "\"{0}\" is not a valid search filter. It is not a UTF8 string."
msgstr "\"{0}\" не є допустимим пошуковим фільтром. Це не рядок UTF8."

msgid "It should be between 1 and 64 char in length."
msgstr "Має мати довжину від 1 до 64 символів."

msgid "\"{0}\" is not a valid user filter."
msgstr "\"{0}\" не є допустимим користувацьким фільтром."

msgid "\"{0}\" is not a valid user id for filter {1}."
msgstr "\"{0}\" не є дійсним ідентифікатором користувача {1}."

msgid "\"{0}\" is not a valid group filter."
msgstr "\"{0}\" не є допустимим груповим фільтром."

msgid "\"{0}\" is not a valid parent filter."
msgstr "\\\"{0}\\\" не є допустимим фільтром-батьком."

msgid "\"{0}\" is not a valid resource id for filter {1}."
msgstr "\"{0}\" не є вірним ідентифікатором користувача для фільтра {1}."

msgid "\"{0}\" is not a valid group id for filter {1}."
msgstr "\"{0}\" не є вірним ідентифікатором групи для фільтра {1}."

msgid "\"{0}\" is not a valid parent id for filter {1}."
msgstr "\\\"{0}\\\" не є дійсним ідентифікатором батька для фільтра {1}."

msgid "\"{0}\" is not a valid timestamp for filter {1}."
msgstr "\"{0}\" не є дійсною міткою часу для фільтра {1}."

msgid "\"{0}\" is not a valid datetime for filter {1}."
msgstr "\"{0}\" не є дійсною датою для фільтра {1}."

msgid "\"{0}\" is not a valid order."
msgstr "\"{0}\" не є допустимим значенням."

msgid "\"{0}\" is not in the list of allowed order."
msgstr "\"{0}\" відсутній в переліку дозволених властивостей."

msgid "\"{0}\" is not a valid contain value."
msgstr "\"{0}\" не є дійсним значенням вмісту."

msgid "undefined user agent"
msgstr "невизначений агент користувача"

msgid "Access restricted to administrators."
msgstr "Доступ тільки для адміністраторів."

msgid "Access restricted to unauthenticated users."
msgstr "Доступ обмежено для неавтентифікованих користувачів."

msgid "The user should not be logged in."
msgstr "Користувач не повинен бути авторизований."

msgid "This feature is not supported by your version of passbolt."
msgstr "Ця функція не підтримується вашою версією Passbolt."

msgid "The resource identifier should be a valid UUID."
msgstr "Ідентифікатор ресурсу має бути дійсним UUID."

msgid "The resource was marked as favorite."
msgstr "Ресурс позначено як обраний."

msgid "The favorite id is not valid."
msgstr "Ідентифікатор обраного недійсний."

msgid "The favorite was deleted."
msgstr "Обране видалено."

msgid "The OpenPGP key identifier should be a valid UUID."
msgstr "Ідентифікатор ключа OpenPGP має бути дійсним UUID."

msgid "The OpenPGP key does not exist."
msgstr "Ключ OpenPGP не існує."

msgid "The group has been added successfully."
msgstr "Групу успішно додано."

msgid "The group can be deleted."
msgstr "Групу можна видалити."

msgid "The group was deleted successfully."
msgstr "Групу успішно видалено."

msgid "You are not authorized to access that location."
msgstr "Ви не маєте дозволу на доступ до цього розташування."

msgid "The group identifier should be a valid UUID."
msgstr "Ідентифікатор групи має бути дійсним UUID."

msgid "The group does not exist or has been already deleted."
msgstr "Група не існує або вже була видалена."

msgid "The group cannot be deleted."
msgstr "Групу неможливо видалити."

msgid "The permissions identifiers must be valid UUID."
msgstr "Ідентифікатори дозволів мають бути дійсними UUID."

msgid "The group id is not valid."
msgstr "Ідентифікатор групи недійсний."

msgid "The group does not exist."
msgstr "Група не існує."

msgid "All checks ran successfully!"
msgstr "Усі перевірки виконано успішно!"

msgid "Healthcheck security index endpoint disabled."
msgstr "Кінцева точка перевірки безпеки Healthcheck вимкнена."

msgid "OK"
msgstr "OK"

msgid "The identifier should be a valid UUID."
msgstr "Ідентифікатор має бути дійсним UUID."

msgid "The resource does not exist."
msgstr "Ресурс не існує."

msgid "The resource has been added successfully."
msgstr "Ресурс було додано успішно."

msgid "The resource has been deleted successfully."
msgstr "Ресурс успішно видалено."

msgid "You do not have the permission to delete this resource."
msgstr "Ви не маєте дозволу на видалення цього ресурсу."

msgid "Could not delete the resource."
msgstr "Не вдалося видалити ресурс."

msgid "The resource has been updated successfully."
msgstr "Ресурс успішно оновлено."

msgid "The role was deleted."
msgstr "Роль видалено."

msgid "The role identifier is not valid."
msgstr ""

msgid "The role was successfully updated."
msgstr "Роль успішно оновлено."

msgid "The secret does not exist."
msgstr "Секрет не існує."

msgid "Only guests are allowed to abort recovery process."
msgstr "Тільки гостям дозволено скасувати процес відновлення."

msgid "An authentication token must be provided."
msgstr "Необхідно вказати токен автентифікації."

msgid "The recovery process was aborted."
msgstr "Процес відновлення було перервано."

msgid "Only guests are allowed to complete setup."
msgstr "Тільки гостям дозволено завершити встановлення."

msgid "The recovery was completed successfully."
msgstr "Відновлення завершено успішно."

msgid "Only guests are allowed to proceed with account recovery."
msgstr "Тільки гостям дозволено продовжити відновлення облікового запису."

msgid "The setup was completed successfully."
msgstr "Налаштування успішно завершено."

msgid "Only guests are allowed to start setup."
msgstr "Тільки гостям дозволено розпочати встановлення."

msgid "You are not authorized to share this resource."
msgstr "Ви не маєте прав поширювати цей ресурс."

msgid "Resource metadata key type is invalid."
msgstr "Тип ключа метаданих ресурсу є недійсним."

msgid "Only administrators can add new users."
msgstr "Тільки адміністратори можуть додавати нових користувачів."

msgid "The user was successfully added. This user now need to complete the setup."
msgstr "Користувача успішно додано. Цьому користувачеві тепер потрібно завершити встановлення."

msgid "The user can be deleted."
msgstr "Користувач може бути видалений."

msgid "The user has been deleted successfully."
msgstr "Користувача успішно видалено."

msgid "The user identifier should be a valid UUID."
msgstr "Ідентифікатор користувача має бути дійсним UUID."

msgid "You are not allowed to delete yourself."
msgstr "Ви не можете видалити самого себе."

msgid "The user does not exist or has been already deleted."
msgstr "Користувач не існує або вже був видалений."

msgid "The user cannot be deleted."
msgstr "Неможливо видалити користувача."

msgid "The groups users identifiers must be valid UUID."
msgstr "Ідентифікатори користувачів груп мають бути дійсними UUID."

msgid "The user does not exist or has been deleted."
msgstr "Користувач не існує або був видалений."

msgid "Could not validate user data."
msgstr "Не вдалося перевірити дані користувача."

msgid "Could not find the user data after save. Maybe it has been deleted in the meantime."
msgstr "Не вдалося знайти дані користувача після збереження. Можливо, вони були видалені у цей час."

msgid "The user has been updated successfully."
msgstr "Користувача успішно оновлено."

msgid "Some user data should be provided."
msgstr "Потрібно надати деякі дані користувача."

msgid "Updating the OpenPGP key is not allowed."
msgstr "Оновлення ключа OpenPGP не дозволено."

msgid "Updating the groups is not allowed."
msgstr "Оновлення груп не дозволено."

msgid "You are not authorized to edit the role."
msgstr "Ви не маєте дозволу редагувати роль."

msgid "Multiple has-access filters are not supported."
msgstr "Декілька фільтрів доступів не підтримуються."

msgid "This operation is not allowed for this user."
msgstr "Ця операція недоступна для цього користувача."

msgid "Only guests are allowed to recover an account. Please logout first."
msgstr "Тільки гостям дозволено відновити обліковий запис. Будь ласка, спочатку вийдіть."

msgid "Recovery process started, check your email."
msgstr "Процес відновлення запущено, перевірте свою електронну пошту."

msgid "Only guests are allowed to register."
msgstr "Тільки гостям дозволено реєструватися."

msgid "Registration is not opened to public."
msgstr "Реєстрація не відкрита для загального використання."

msgid "Please contact your administrator."
msgstr "Будь ласка, звʼяжіться з адміністратором."

msgid "This is due to a security setting."
msgstr "Це пов'язано з налаштуванням безпеки."

msgid "The user identifier should be a valid UUID or \"me\"."
msgstr "Ідентифікатор користувача має бути дійсним UUID або \"me\"."

msgid "The user does not exist."
msgstr "Користувач не існує."

msgid "No admin were found in the database."
msgstr "В базі даних не знайдено жодного адміністратора."

msgid "The `{0}` configuration must be a valid non-empty string."
msgstr "Налаштування \"{0}\" має бути дійсним непорожнім рядком."

msgid "Invalid expiry time {0}."
msgstr "Неприпустимий час завершення дії {0}."

msgid "The user role ID must not be of the guest role."
msgstr ""

msgid "The identifier should not be empty."
msgstr "Ідентифікатор не повинен бути порожнім."

msgid "The token should be a valid UUID."
msgstr "Токен має бути дійсним UUID."

msgid "A token is required."
msgstr "Потрібен токен."

msgid "The token should not be empty."
msgstr "Токен не повинен бути порожнім."

msgid "The type should be one of the following: {0}."
msgstr "Тип має бути одним із наступних: {0}."

msgid "A type is required."
msgstr "Необхідно вказати тип."

msgid "The type should not be empty."
msgstr "Тип не повинен бути порожнім."

msgid "A user identifier is required."
msgstr "Потрібен ідентифікатор користувача."

msgid "The user identifier should not be empty."
msgstr "Ідентифікатор користувача не повинен бути порожнім."

msgid "The active status should be a valid boolean."
msgstr "Стан активності має бути дійсним логічним значенням."

msgid "An active status is required"
msgstr "Необхідно вказати стан активності"

msgid "It is not possible to create an authentication token for this user."
msgstr "Неможливо створити токен автентифікації для цього користувача."

msgid "A file is required."
msgstr "Потрібен файл."

msgid "The file should not be empty"
msgstr "Файл не повинен бути порожнім"

msgid "The file mime type should be one of the following: {0}."
msgstr "Тип MIME файлу має бути одним із наступних: {0}."

msgid "The file extension should be one of the following: {0}."
msgstr "Розширення файлу має бути одним із наступних: {0}."

msgid "The file is not valid, or exceeds max size of {0} bytes."
msgstr "Файл недійсний або перевищує максимальний розмір {0} байтів."

msgid "Could not save the data in {0} format."
msgstr "Не вдалося зберегти дані у форматі {0}."

msgid "The parent comment identifier should be a valid UUID."
msgstr "Ідентифікатор батьківського коментаря має бути дійсним UUID."

msgid "The commented object type should be one of the following: {0}."
msgstr "Тип коментованого об'єкта має бути одним із наступних: {0}."

msgid "The commented object type is required."
msgstr "Необхідно вказати тип коментованого об'єкта."

msgid "The commented object type should not be empty."
msgstr "Тип коментованого об'єкта не повинен бути порожнім."

msgid "The commented object identifier should be a valid UUID."
msgstr "Ідентифікатор коментованого обʼєкта має бути дійсним UUID."

msgid "The commented object identifier is required."
msgstr "Потрібен ідентифікатор коментованого обʼєкта."

msgid "The commented object identifier should not be empty."
msgstr "Ідентифікатор коментованого обʼєкта не повинен бути порожнім."

msgid "The content should be a valid UTF8 string."
msgstr "Вміст має бути дійсним рядком UTF8."

msgid "A content is required"
msgstr "Необхідно вказати вміст"

msgid "The content should not be empty"
msgstr "Вміст не повинен бути порожнім"

msgid "The content length should be between {0} and {1} characters."
msgstr "Довжина вмісту має бути від {0} до {1} символів."

msgid "The identifier of the user who created the comment should be a valid UUID."
msgstr "Ідентифікатор користувача, який створив коментар, має бути дійсним UUID."

msgid "The identifier of the user who created the comment is required."
msgstr "Потрібен ідентифікатор користувача, який створив коментар."

msgid "The identifier of the user who created the comment should not be empty."
msgstr "Ідентифікатор користувача, який створив коментар, не повинен бути порожнім."

msgid "The identifier of the user who modified the comment should be a valid UUID."
msgstr "Ідентифікатор користувача, який змінив коментар, має бути дійсним UUID."

msgid "The identifier of the user who modified the comment required."
msgstr "Потрібен ідентифікатор користувача, який змінив коментар."

msgid "The identifier of the user who modified the comment should not be empty."
msgstr "Ідентифікатор користувача, який змінив коментар, не повинен бути порожнім."

msgid "Access denied."
msgstr "Доступ заборонено."

msgid "The parent comment does not exist."
msgstr "Батьківський коментар не існує."

msgid "The user cannot update this comment."
msgstr "Користувач не може оновити цей коментар."

msgid "The user cannot delete this comment."
msgstr "Користувач не може видалити цей коментар."

msgid "The commented object type does not exist."
msgstr "Тип коментованого обʼєкта не існує."

msgid "The favorite object type should be one of the following: {0}."
msgstr "Тип обʼєкта обраного має бути одним із наступних: {0}."

msgid "The favorite object type is required."
msgstr "Необхідно вказати тип обʼєкта обраного."

msgid "The favorite object type should not be empty"
msgstr "Тип обʼєкта обраного не повинен бути порожнім"

msgid "The favorite object identifier should be a valid UUID."
msgstr "Ідентифікатор обʼєкта обраного має бути дійсним UUID."

msgid "The favorite object identifier is required."
msgstr "Необхідно вказати ідентифікатор обʼєкта обраного."

msgid "The favorite object identifier should not be empty."
msgstr "Ідентифікатор обʼєкта обраного не повинен бути порожнім."

msgid "The resource is already marked as favorite."
msgstr "Ресурс уже позначено як обраний."

msgid "The user cannot delete this favorite."
msgstr "Користувач не може видалити це обране."

msgid "The armored key should be a valid ASCII string."
msgstr "ASCII-armor ключ має бути дійсним рядком ASCII."

msgid "An armored key is required."
msgstr "Потрібен ASCII-armor ключ."

msgid "The armored key should not be empty."
msgstr "ASCII-armor ключ не повинен бути порожнім."

msgid "The fingerprint should be a valid ASCII string."
msgstr "Відбиток має бути дійсним рядком ASCII."

msgid "A fingerprint is required"
msgstr "Потрібен відбиток"

msgid "The fingerprint should not be empty"
msgstr "Відбиток не повинен бути порожнім"

msgid "A length is required."
msgstr "Потрібно вказати довжину."

