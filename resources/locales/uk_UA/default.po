msgid "This user lost their private key and/or passphrase and cannot complete the account recovery process."
msgstr "Цей користувач втратив свій приватний ключ та/або парольну фразу і не може завершити процес відновлення облікового запису."

msgid "Unfortunately, they will need your help to delete their account and restart from scratch."
msgstr "На жаль, їм потрібна ваша допомога, щоб видалити їхній обліковий запис і почати спочатку."

msgid "Please check with them first to confirm."
msgstr "Будь ласка, спочатку уточніть у них, щоб переконатися."

msgid "User suspended"
msgstr "Користувача призупинено"

msgid "The user {0} has been suspended."
msgstr "Користувач {0} був призупинений."

msgid "This user will not be able to sign in to passbolt and receive email notifications."
msgstr "Цей користувач не зможе увійти в Passbolt та отримувати сповіщення електронною поштою."

msgid "Other users can share resources and add this user to a group."
msgstr "Інші користувачі можуть ділитися ресурсами та додавати цього користувача до групи."

msgid "Check user suspension"
msgstr "Перевірте призупинення користувача"

msgid "Welcome to {0}!"
msgstr "Ласкаво просимо до {0}!"

msgid "{0} used the self registration feature to create an account on passbolt."
msgstr "{0} використав(ла) функцію самореєстрації, щоб створити обліковий запис у passbolt."

msgid "{0} just activated their account on passbolt!"
msgstr "{0} щойно активував(ла) свій обліковий запис у Passbolt!"

msgid "The user is now active on passbolt and you can share passwords with them."
msgstr "Тепер користувач активний у Passbolt і ви можете поділитись із ним паролями."

msgid "This user was invited by you {0}."
msgstr "Цей користувач був запрошений вами {0}."

msgid "This user signed up themselves, since the public registration is enabled."
msgstr "Цей користувач зареєструвався самостійно, оскільки публічна реєстрація увімкнена."

msgid "This user was invited by {0} {1}."
msgstr "Цей користувач був запрошений {0} {1}."

msgid "This user is missing the encryption key for the shared resource metadata. Please log in and go the user workspace and share the key with them manually."
msgstr "Цьому користувачу бракує ключа шифрування для метаданих спільного ресурсу. Будь ласка, увійдіть і відкрийте робочий простір користувача, а потім поділіться з ним ключем вручну."

msgid "View users"
msgstr "Переглянути користувачів"

msgid "Welcome back!"
msgstr "З поверненням!"

msgid "You just requested to recover your passbolt account on this device."
msgstr "Ви щойно запросили відновлення свого облікового запису Passbolt на цьому пристрої."

msgid "Make sure you have a backup of your secret key handy."
msgstr "Переконайтеся, що у вас є резервна копія вашого секретного ключа."

msgid "Click on the link below to proceed."
msgstr "Натисніть на посилання нижче, щоб продовжити."

msgid "start recovery"
msgstr "почати відновлення"

msgid "You just completed an account recovery. Feel free to get in touch with an admin if you feel this action looks suspicious."
msgstr "Ви щойно завершили відновлення облікового запису. Якщо вам здається, що ця дія викликає підозри, зв’яжіться з адміністратором."

msgid "{0} just created an account for you on passbolt!"
msgstr "{0} щойно створив(ла) для вас обліковий запис у Passbolt!"

msgid "Welcome {0}"
msgstr "Ласкаво просимо {0}"

msgid "{0} just invited you to join passbolt at {1}"
msgstr "{0} щойно запросив(ла) вас приєднатися до Passbolt на {1}"

msgid "Passbolt is an open source password manager."
msgstr "Passbolt — це менеджер паролів з відкритим кодом."

msgid "It is designed to allow sharing credentials securely with your team!"
msgstr "Він створений, щоб безпечно ділитися обліковими даними з вашою командою!"

msgid "Let's take the next five minutes to get you started!"
msgstr "Давайте витратимо наступні п’ять хвилин, щоб розпочати роботу!"

msgid "get started"
msgstr "почати"

msgid "You just created your account on passbolt!"
msgstr "Ви щойно створили свій обліковий запис у Passbolt!"

msgid "You just opened an account on passbolt at {0}."
msgstr "Ви щойно відкрили обліковий запис у Passbolt на {0}."

msgid "Get started"
msgstr "Почати"

msgid "There was a change in the user directory."
msgstr "У каталозі користувачів сталася зміна."

msgid "You have been requested to add members to a group."
msgstr "Вас було запрошено додати учасників до групи."

msgid "{0} requested you to add members to a group"
msgstr "{0} попросив вас додати учасників до групи"

msgid "Group: {0}"
msgstr "Група: {0}"

msgid "The following members should be added:"
msgstr "Слід додати наступних учасників:"

