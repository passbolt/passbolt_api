msgstr "{0} ініціював запит на відновлення облікового запису"

msgid "Recovery request"
msgstr "Запит на відновлення"

msgid "{0} has initiated an account recovery request."
msgstr "{0} ініціював(ла) запит на відновлення облікового запису."

msgid "Since you’re authorized to handle account recovery requests, please process this one."
msgstr ""

msgid "You will need your organization recovery key to continue."
msgstr "Вам знадобиться ключ відновлення організації, щоб продовжити."

msgid "Review the recovery request"
msgstr "Переглянути запит на відновлення"

msgid "Suspicious recovery request"
msgstr "Підозрілий запит на відновлення"

msgid "An account recovery request was attempted from a user with client IP {0} for {1}."
msgstr "Спробу відновлення облікового запису зробив користувач з IP-адреси клієнта {0} для {1}."

msgid "The request could not be found in the database."
msgstr "Не вдалося знайти запит у базі даних."

msgid "This is a potential security threat."
msgstr "Це може становити потенційну загрозу безпеці."

msgid "You have initiated an account recovery!"
msgstr "Ви ініціювали відновлення облікового запису!"

msgid "Recovery Request"
msgstr "Запит на відновлення"

msgid "You just requested an account recovery."
msgstr "Ви щойно ініціювали відновлення облікового запису."

msgid "Your administrator have been informed and will follow up with you."
msgstr "Ваш адміністратор був поінформований і зв’яжеться з вами."

msgid "If you did not make this request please inform your administrator."
msgstr "Якщо ви не робили цей запит, будь ласка, повідомте свого адміністратора."

msgid "You have updated a recovery request to {0}."
msgstr "Ви оновили запит на відновлення до {0}."

msgid "You have set the status of the account recovery request initiated by {0} ({1}) to {2}."
msgstr "Ви встановили статус запиту на відновлення облікового запису, ініційованого {0} ({1}), на {2}."

msgid "{0} ({1}) has updated a recovery request to {2}."
msgstr "{0} ({1}) оновив(ла) запит на відновлення до {2}."

msgid "{0} ({1}) has set the status of the request initiated by {2} ({3}) to {4}."
msgstr "{0} ({1}) встановив(ла) статус запиту, ініційованого {2} ({3}), на {4}."

msgid "{0} ({1}) has approved your recovery request."
msgstr "{0} ({1}) схвалив(ла) ваш запит на відновлення."

msgid "Your organization recovery contacts have reviewed and approved your account recovery request."
msgstr "Контакти вашої організації з відновлення розглянули та схвалили ваш запит на відновлення облікового запису."

msgid "Please click on the link below to continue."
msgstr "Будь ласка, натисніть на посилання нижче, щоб продовжити."

msgid "Important"
msgstr "Важливо"

msgid "Please use the same computer and browser that you used to initiate the request."
msgstr "Будь ласка, використовуйте той самий комп’ютер і браузер, які ви використовували для ініціювання запиту."

msgid "Complete account recovery"
msgstr "Завершити відновлення облікового запису"

msgid "{0} ({1}) has denied your recovery request."
msgstr "{0} ({1}) відхилив(ла) ваш запит на відновлення."

msgid "Your organization recovery contacts have reviewed and rejected your account recovery request."
msgstr "Контакти вашої організації з відновлення розглянули та відхилили ваш запит на відновлення облікового запису."

msgid "Only administrators can view user logs."
msgstr "Тільки адміністратори можуть переглядати журнали користувачів."

msgid "The user {0} could not be added to group {1} because there is no matching directory entry in passbolt."
msgstr "Користувача {0} не вдалося додати до групи {1}, оскільки в passbolt не знайдено відповідного запису в довіднику."

msgid "The user {0} could not be added to the group {1} because the membership has been removed in passbolt"
msgstr "Користувача {0} не вдалося додати до групи {1}, оскільки членство було вилучено в passbolt."

msgid "The user {0} was not synced with existing membership for group {1} because the membership was created before."
msgstr "Користувача {0} не було синхронізовано з наявним членством групи {1}, оскільки це членство було створено раніше."

msgid "The user {0} was successfully added to the group {1}."
msgstr "Користувача {0} успішно додано до групи {1}."

msgid "The user {0} could not be added to the group {1} because their account was priorly deleted in passbolt."
msgstr "Користувача {0} не вдалося додати до групи {1}, оскільки його обліковий запис раніше було видалено в Passbolt."

msgid "The user {0} could not be added to the group {1} because they have not yet activated their account."
msgstr "Користувача {0} не вдалося додати до групи {1}, оскільки він ще не активував свій обліковий запис."

msgid "The user {0} could not be added to the group {1} because of validation issues."
msgstr "Користувача {0} не вдалося додати до групи {1} через проблеми валідації."

msgid "The user {0} could not be added to the group {1} because of an internal error."
msgstr "Користувача {0} не вдалося додати до групи {1} через внутрішню помилку."

msgid "The user {0} cannot be added to the group {1} automatically. An email request was sent to the group manager(s) to do it manually."
msgstr "Користувача {0} неможливо було автоматично додати до групи {1}. Електронний запит було надіслано менеджеру(ам) групи, щоб зробити це вручну."

msgid "The user {0} was successfully removed from the group {1}."
msgstr "Користувача {0} успішно видалено з групи {1}."

msgid "The user {0} could not be removed from the group {1} because it is the only group manager."
msgstr "Користувача {0} не вдалося видалити з групи {1}, оскільки він єдиний менеджер групи."

msgid "The user {0} could not be removed from the group {1} because some validation issues."
msgstr "Користувача {0} не вдалося видалити з групи {1} через проблеми валідації."

msgid "The user {0} could not be removed from the group {1} because of an internal error."
msgstr "Користувача {0} не вдалося видалити з групи {1} через внутрішню помилку."

msgid "The user {0} was successfully synced with the group {1}."
msgstr "Користувача {0} успішно синхронізовано з групою {1}."

msgid "The group {0} has been successfully renamed to {1}."
msgstr "Групу {0} успішно перейменовано на {1}."

msgid "The group {0} could not be renamed to {1}."
msgstr "Не вдалося перейменувати групу {0} на {1}."

msgid "The passbolt {0} {1} was not deleted because it is marked as to be ignored."
msgstr "{0} {1} у passbolt не було видалено, оскільки він позначений як ігнорований."

msgid "The directory {0} {1} was not deleted because it is ignored."
msgstr "{0} {1} з довідника не було видалено, оскільки він ігнорується."

msgid "The directory user {0} was already suspended in passbolt."
msgstr "Користувач каталогу {0} вже був призупинений в Passbolt."

msgid "The directory {0} {1} was already deleted in passbolt."
msgstr "{0} {1} з довідника вже було видалено у passbolt."

msgid "The user {0} could not be deleted because they are the only owner of one or more passwords."
msgstr "Користувача {0} не вдалося видалити, оскільки він єдиний власник одного або декількох паролів."

msgid "The {0} {1} could not be deleted because they are the only manager of one or more groups."
msgstr "{0} {1} не вдалося видалити, оскільки він є єдиним менеджером однієї чи декількох груп."

msgid "The user {0} was successfully suspended."
msgstr "Користувача {0} успішно призупинено."

msgid "The {0} {1} was successfully deleted."
msgstr "{0} {1} успішно видалено."

msgid "The {0} {1} could not be suspended because of an internal error. Please try again later."
msgstr "Не вдалося призупинити {0} {1} через внутрішню помилку. Спробуйте пізніше."

msgid "The {0} {1} could not be deleted because of an internal error. Please try again later."
msgstr "{0} {1} не вдалося видалити через внутрішню помилку. Будь ласка, спробуйте пізніше."

msgid "The {0} {1} was not synced because the passbolt {0} is marked as to be ignored."
msgstr "{0} {1} не синхронізовано, оскільки {0} у passbolt позначений як ігнорований."

msgid "The {0} {1} was not synced because the directory {0} is marked as to be ignored."
msgstr "{0} {1} не синхронізовано, оскільки {0} у довіднику позначений як ігнорований."

msgid "The {0} {1} was successfully added to passbolt."
msgstr "{0} {1} було успішно додано до passbolt."

msgid "The {0} {1} could not be added because of data validation issues."
msgstr "{0} {1} не вдалося додати через проблеми з валідацією даних."

msgid "The {0} {1} could not be added because of an internal error. Please try again later."
msgstr "{0} {1} не вдалося додати через внутрішню помилку. Будь ласка, спробуйте пізніше."

msgid "The previously suspended {0} {1} was not unsuspended."
msgstr "Раніше призупинений {0} {1} не було відновлено."

msgid "The previously deleted {0} {1} was not re-added to passbolt."
msgstr "Раніше видалений {0} {1} не було повторно додано до passbolt."

msgid "The previously suspended {0} {1} was unsuspended."
msgstr "Раніше призупинений {0} {1} було відновлено."

msgid "The previously deleted {0} {1} was re-added to passbolt."
msgstr "Раніше видалений {0} {1} було повторно додано до passbolt."

msgid "The deleted {0} {1} could not be re-added to passbolt because of validation errors."
msgstr "Раніше видалений {0} {1} не вдалося повторно додати до passbolt через помилки валідації."

msgid "The deleted {0} {1} could not be re-added to passbolt because of an internal error."
msgstr "Раніше видалений {0} {1} не вдалося повторно додати до passbolt через внутрішню помилку."

msgid "The {0} {1} was mapped with an existing {0} in passbolt."
msgstr "{0} {1} було зіставлено з наявним {0} у passbolt."

msgid "The {0} {1} could not be mapped with an existing {0} in passbolt because it was created after."
msgstr "{0} {1} не вдалося зіставити з наявним {0} у passbolt, оскільки воно було створено пізніше."

msgid "The user {0} full name has been successfully updated to {1} {2}."
msgstr "Повне ім’я користувача {0} було успішно змінено на {1} {2}."

msgid "The user {0} full name could not be updated to {1} {2}."
msgstr "Не вдалося змінити повне ім’я користувача {0} на {1} {2}."

msgid "The record model is not valid."
msgstr "Модель запису недійсна."

msgid "The record is currently ignored as part of directory synchronization."
msgstr "Цей запис наразі ігнорується в процесі синхронізації довідника."

msgid "The record is currently not ignored as part of directory synchronization."
msgstr "Зараз запис не ігнорується в процесі синхронізації довідника."

msgid "The record will be ignored in the next directory synchronization."
msgstr "Запис буде ігноруватися під час наступної синхронізації довідника."

msgid "The record id is not valid."
msgstr "Ідентифікатор запису недійсний."

msgid "The record does not exist."
msgstr "Запис не існує."

msgid "The record could not be unmarked as ignored. Please try again later."
msgstr "Неможливо зняти позначку ігнорування з цього запису. Будь ласка, спробуйте пізніше."

msgid "The record will not be ignored in the next directory synchronization."
msgstr "Запис не буде ігноруватися під час наступної синхронізації довідника."

msgid "Could not validate settings."
msgstr "Неможливо перевірити налаштування."

msgid "Could not save the settings. {0}"
msgstr "Неможливо зберегти налаштування. {0}"

msgid "The directory structure cannot be retrieved."
msgstr "Неможливо отримати структуру довідника."

msgid "There was an issue while retrieving the invalid entries."
msgstr "Сталася проблема під час отримання недійсних записів."

msgid "The synchronization was done successfully."
msgstr "Синхронізацію успішно завершено."

msgid "The simulation was done successfully."
msgstr "Симуляцію успішно завершено."

msgid "Need at least one domain configuration."
msgstr "Потрібна щонайменше одна конфігурація домену."

msgid "The connection name `{0}` should not contain dots"
msgstr "Ім’я з’єднання `{0}` не повинно містити крапок."

msgid "Invalid connection name"
msgstr "Неприпустиме ім’я з’єднання"

msgid "The identifier of the default admin user is required."
msgstr "Потрібен ідентифікатор користувача-адміністратора за замовчуванням."

msgid "The identifier of the default admin user should not be empty."
msgstr "Ідентифікатор користувача-адміністратора за замовчуванням не повинен бути порожнім."

msgid "The identifier of the default admin user should be a valid UUID."
msgstr "Ідентифікатор користувача-адміністратора за замовчуванням має бути дійсним UUID."

msgid "The admin user does not exist."
msgstr "Користувач-адміністратор не існує."

msgid "The identifier of the default group admin user is required."
msgstr "Потрібен ідентифікатор адміністратора групи за замовчуванням."

msgid "The identifier of the default group admin user should not be empty."
msgstr "Ідентифікатор адміністратора групи за замовчуванням не повинен бути порожнім."

msgid "The identifier of the default group admin user should be a valid UUID."
msgstr "Ідентифікатор адміністратора групи за замовчуванням має бути дійсним UUID."

msgid "The group admin user does not exist."
msgstr "Адміністратор групи не існує."

msgid "The group object class should be a valid BMP-UTF8 string."
msgstr "Клас об'єкта групи має бути дійсним BMP-UTF8 рядком."

msgid "The user object class should be a valid BMP-UTF8 string."
msgstr "Клас об'єкта користувача має бути дійсним BMP-UTF8 рядком."

msgid "The user path should be a valid BMP-UTF8 string."
msgstr "Шлях користувача має бути дійсним BMP-UTF8 рядком."

msgid "The group custom filter should be a valid BMP-UTF8 string."
msgstr "Спеціальний фільтр групи повинен бути дійсним рядком BMP-UTF8."

msgid "The user custom filter should be a valid BMP-UTF8 string."
msgstr "Спеціальний фільтр користувача має бути дійсним рядком BMP-UTF8."

msgid "The email prefix/suffix setting should be a valid boolean."
msgstr "Налаштування префікса/суфікса електронної пошти має бути дійсним логічним значенням."

msgid "The email prefix should be a valid BMP-UTF8 string."
msgstr "Префікс електронної пошти має бути дійсним BMP-UTF8 рядком."

msgid "The email suffix should be a valid BMP-UTF8 string."
msgstr "Суфікс електронної пошти має бути дійсним BMP-UTF8 рядком."

msgid "The users parent group should be a valid BMP-UTF8 string."
msgstr "Група батьків для користувачів має бути дійсним BMP-UTF8 рядком."

msgid "The groups parent group should be a valid BMP-UTF8 string."
msgstr "Група батьків для груп має бути дійсним BMP-UTF8 рядком."

msgid "The enabled users only setting should be a boolean."
msgstr "Налаштування \"лише дозволені користувачі\" має бути логічним значенням."

msgid "The sync of created users setting should be a boolean."
msgstr "Налаштування синхронізації створених користувачів має бути логічним значенням."

msgid "The sync of updated users setting should be a boolean."
msgstr "Налаштування синхронізації оновлених користувачів має бути логічним значенням."

msgid "The sync of deleted users setting should be a boolean."
msgstr "Налаштування синхронізації видалених користувачів має бути логічним значенням."

msgid "The sync of created groups setting should be a boolean."
msgstr "Налаштування синхронізації створених груп має бути логічним значенням."

msgid "The sync of deleted groups setting should be a boolean."
msgstr "Налаштування синхронізації видалених груп має бути логічним значенням."

msgid "The sync of updated groups setting should be a boolean."
msgstr "Налаштування синхронізації оновлених груп має бути логічним значенням."

msgid "The fields mapping should be a valid array."
msgstr "Відображення полів має бути дійсним масивом."

msgid "A directory type is required."
msgstr "Потрібно вказати тип довідника."

msgid "The directory type should not be empty."
msgstr "Тип довідника не повинен бути порожнім."

msgid "The directory type should be one of the following: {0}."
msgstr "Тип довідника має бути одним із наступних: {0}."

msgid "A domain name is required."
msgstr "Потрібна назва домену."

msgid "The domain name should not be empty."
msgstr "Назва домену не повинна бути порожньою."

msgid "The domain name should be a valid BMP-UTF8 string."
msgstr "Назва домену має бути дійсним BMP-UTF8 рядком."

msgid "The base DN should be a valid BMP-UTF8 string."
msgstr "Base DN має бути дійсним BMP-UTF8 рядком."

msgid "At least one host is required."
msgstr "Потрібен принаймні один хост."

msgid "The hosts should be a valid array."
msgstr "Хости мають бути дійсним масивом."

msgid "The port number should not be empty."
msgstr "Номер порту не повинен бути порожнім."

msgid "The port number should be between 0 and 65535"
msgstr "Номер порту має бути в діапазоні від 0 до 65535."

msgid "A connection type is required."
msgstr "Потрібно вказати тип з'єднання."

msgid "The connection type should not be empty."
msgstr "Тип з'єднання не повинен бути порожнім."

msgid "The connection type should be one of the following: {0}."
msgstr "Тип з'єднання має бути одним із таких: {0}."

msgid "An authentication type is required."
msgstr "Потрібно вказати тип автентифікації."

msgid "The authentication type should not be empty."
msgstr "Тип автентифікації не повинен бути порожнім."

msgid "The authentication type should be one of the following: {0}."
msgstr "Тип автентифікації має бути одним із наступних: {0}."

msgid "The map for this field is required."
msgstr "Відображення для цього поля є обов’язковим."

msgid "The map value should not be empty."
msgstr "Значення відображення не повинно бути порожнім."

msgid "The field name should be a valid BMP-UTF8 string."
msgstr "Назва поля має бути дійсним рядком BMP-UTF8."

msgid "The map value length should be maximum {0} characters."
msgstr "Довжина значення відображення має бути не більше {0} символів."

msgid "The map value should not be from forbidden fields."
msgstr "Значення відображення не повинно мати заборонених полів."

msgid "The map configuration for `{0}` fields is required."
msgstr "Налаштування відображення для полів `{0}` є обов’язковим."

msgid "The group object class length should be maximum {0} characters."
msgstr "Довжина об’єктного класу групи має бути не більше {0} символів."

msgid "The group object class should not be from forbidden fields."
msgstr "Об’єктний клас групи не повинен містити заборонених полів."

msgid "The user object class length should be maximum {0} characters."
msgstr "Довжина об’єктного класу користувача має бути не більше {0} символів."

msgid "The user object class should not be from forbidden fields."
msgstr "Об’єктний клас користувача не повинен містити заборонених полів."

msgid "The user custom filter length should be maximum {0} characters."
msgstr "Довжина спеціального фільтра користувача має бути не більше {0} символів."

msgid "The user custom filter contains the forbidden field."
msgstr "Спеціальний фільтр користувача містить заборонене поле."

msgid "The group custom filter length should be maximum {0} characters."
msgstr "Довжина спеціального фільтра групи має бути не більше {0} символів."

msgid "The group custom filter contains the forbidden field."
msgstr "Спеціальний фільтр групи містить заборонене поле."

msgid "The field fallbacks should be a valid array."
msgstr "Поле fallbacks має бути коректним масивом."

msgid "The field fallbacks should not be empty."
msgstr "Поле fallbacks не повинно бути порожнім."

msgid "The field fallbacks keys should be one of the following: {0}."
msgstr "Ключі поля fallbacks мають бути одним із наступних: {0}."

msgid "The fallback field value should be a valid BMP-UTF8 string."
msgstr "Значення поля fallback має бути коректним рядком BMP-UTF8."

msgid "The fallback field value length should be maximum {0} characters."
